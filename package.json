{
  "name": "blackroad-os-home",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:home": "next start -p ${PORT:-3000}",
    "postbuild": "pnpm run generate:toc && pnpm run sign:beacon",
    "lint": "eslint . --ext .ts,.tsx,.md,.mdx",
    "generate:toc": "tsx scripts/generate-toc.ts",
    "sign:beacon": "tsx scripts/postbuild.ts",
    "deploy": "pnpm build && pnpm exec gh-pages -d out"
  },
  "dependencies": {
    "flexsearch": "0.7.43",
    "next": "16.1.6",
    "nextra": "2.13.3",
    "nextra-theme-docs": "2.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-mdx": "3.1.5",
    "gh-pages": "6.3.0",
    "globby": "14.0.2",
    "gray-matter": "4.0.3",
    "prettier": "3.3.3",
    "serve": "14.2.0",
    "tsx": "4.15.7",
    "typescript": "5.4.5",
    "eslint-mdx": "3.3.0"
  }
}
